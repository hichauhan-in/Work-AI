# Optional environment overrides, loaded automatically via python-dotenv.
# Copy to ".env" on the runtime machine ONLY if you need these. Most settings live in config.yaml.
# .env is git-ignored.

# Point at a non-default Ollama server (overrides ollama.host in config.yaml):
# OLLAMA_HOST=http://localhost:11434

# Use a config file other than ./config.yaml:
# PERSONALAI_CONFIG=config.yaml
